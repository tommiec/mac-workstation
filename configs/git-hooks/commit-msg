#!/bin/sh
# Block accidental AI tool traces in commit messages.
#
# This hook is intentionally message-only: it does not inspect code, docs or
# staged content. It prevents the most common leakage path: trailers and commit
# subjects/bodies added by assistants or IDE integrations.

msg_file="$1"

if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
    exit 0
fi

blocked_trailer_re='^(Co-authored-by|Co-Authored-By|Generated-by|Generated-By|Created-by|Created-By|Assisted-by|Assisted-By|Pair-programmed-with|Pair-Programmed-With):.*(AI|Bot|Assistant|Agent|Claude|Codex|OpenAI|Anthropic|Gemini|GPT|LLM|Copilot|Aider|Cline|Cursor|Windsurf|Continue|Roo|OpenHands)'
blocked_tool_re='(Claude|Claude Code|Codex|ChatGPT|OpenAI|Anthropic|Gemini|GitHub Copilot|Aider|Cline|Cursor|Windsurf|Roo Code|OpenHands)'

if grep -Eiq "$blocked_trailer_re" "$msg_file"; then
    cat >&2 <<'EOF'
Commit blocked: AI-related commit trailer detected.

Remove assistant/tool trailers such as Co-Authored-By, Generated-By,
Assisted-By or similar before committing.
EOF
    exit 1
fi

if grep -Eiq "$blocked_tool_re" "$msg_file"; then
    cat >&2 <<'EOF'
Commit blocked: AI tool/vendor name detected in the commit message.

Write the commit message in normal project terms: what changed and why.
Do not mention assistant/tool names in commit history.
EOF
    exit 1
fi

exit 0
